# ──────────────────────────────────────────────
# FOMbot — Cloud-Native Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Server ────────────────────────────────────
PORT=3000

# ── PostgreSQL ────────────────────────────────
# Render / Railway / Supabase / Neon provide this automatically
DATABASE_URL=postgresql://user:password@host:5432/fombot?sslmode=require

# ── Cloudflare R2 (S3-Compatible) ─────────────
# Get these from Cloudflare Dashboard → R2 → Manage R2 API Tokens
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=fombot-uploads
S3_ACCESS_KEY=your-r2-access-key-id
S3_SECRET_KEY=your-r2-secret-access-key

# Public URL for your R2 bucket (if you enabled public access or custom domain)
# Leave empty to use the built-in file proxy endpoint (/api/files/:key)
S3_PUBLIC_URL=

# ── Telegram Webhooks ─────────────────────────
# Your app's public HTTPS URL (no trailing slash)
# Examples: https://fombot.onrender.com, https://fombot.up.railway.app
WEBHOOK_URL=https://your-app-url.com

# Secret used to derive per-bot webhook verification tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=change-me-to-a-random-string
